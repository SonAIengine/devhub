# devhub 환경변수
# 이 파일을 .env로 복사 후 사용할 플랫폼 키만 입력하세요.

# ── Dev.to ──────────────────────────────────────
# https://dev.to/settings/extensions → API Keys
DEVTO_API_KEY=

# ── Bluesky ─────────────────────────────────────
# https://bsky.app/settings → App Passwords
BLUESKY_HANDLE=your.handle.bsky.social
BLUESKY_APP_PASSWORD=

# ── Twitter/X 읽기 (twikit) ────────────────────
# 무료 — X 계정 로그인 기반
TWITTER_USERNAME=
TWITTER_EMAIL=
TWITTER_PASSWORD=
TWITTER_COOKIE_PATH=       # 기본: ~/.devhub/twitter_cookies.json

# ── Twitter/X 쓰기 (tweepy) ────────────────────
# 공식 API — https://developer.x.com/en/portal/dashboard
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# ── Reddit ──────────────────────────────────────
# https://www.reddit.com/prefs/apps → create app (script type)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
REDDIT_USER_AGENT=devhub/0.1.0

# ── GitHub Discussions ──────────────────────────
# https://github.com/settings/tokens
GITHUB_TOKEN=
GITHUB_DISCUSSIONS_REPOS=owner/repo,owner2/repo2
GITHUB_DISCUSSIONS_DEFAULT_REPO=
GITHUB_DISCUSSIONS_CATEGORY_ID=
GITHUB_USERNAME=

# ── Discourse ───────────────────────────────────
# https://meta.discourse.org/t/discourse-rest-api-documentation/22706
DISCOURSE_BASE_URL=
DISCOURSE_BASE_URLS=
DISCOURSE_DEFAULT_BASE_URL=
DISCOURSE_API_KEY=
DISCOURSE_API_USERNAME=
DISCOURSE_DEFAULT_CATEGORY_ID=
